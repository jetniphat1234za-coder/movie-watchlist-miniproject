generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Watchlist {
  id        Int      @id @default(autoincrement())
  title     String
  tmdbId    Int?     // TMDB ID
  imdbId    String?  // IMDb ID
  rating    Int      // 1-10 (how much want to watch)
  comment   String?
  
  // TMDB Data
  posterPath    String?
  overview      String?
  tmdbRating    Float?   // TMDB vote average
  genres        String?  // JSON array of genres
  releaseDate   String?
  
  createdAt DateTime @default(now())
}