generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Watchlist {
  id        Int      @id @default(autoincrement())
  title     String
  imdbId    String?  // ไอดีอ้างอิงจาก API ภายนอก
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
}